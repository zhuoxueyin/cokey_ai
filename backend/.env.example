# AIGC创作平台 - 配置文件示例

# 应用配置
APP_NAME=AIGC创作平台
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# MongoDB
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=aigc_platform

# Redis
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# 加密密钥（生产环境请更换）
SECRET_KEY=your-secret-key-change-in-production-please
ENCRYPTION_KEY=your-32bytes-encryption-key-here!

# GitHub 存储配置（文件上传和生成结果存储）
# - GITHUB_TOKEN: GitHub Personal Access Token（需要 repo 权限）
# - GITHUB_REPO: 仓库名（格式：owner/repo），文件存到该仓库的 assets/ 目录
# - GITHUB_BRANCH: 分支名
# - GITHUB_CDN_PREFIX: CDN 镜像前缀，默认使用 jsDelivr 国内镜像
GITHUB_TOKEN=your-github-personal-access-token
GITHUB_REPO=zhuoxueyin/cokey_ai
GITHUB_BRANCH=main
GITHUB_CDN_PREFIX=https://cdn.jsdmirror.com/gh

# Weelink 渠道 API Key（文本/图像/视频生成模型调用）
# 获取地址: https://api.weelink.ai
# 说明: 如果数据库中的渠道配置为占位符，将自动使用此环境变量
WEELINK_API_KEY=your-weelink-api-key-here

# 限流配置
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_WINDOW_SECONDS=60

# 任务超时与重试
TASK_TIMEOUT_SECONDS=300
TASK_RETRY_MAX=3
TASK_RETRY_DELAY=5

# 前端轮询间隔（毫秒）
POLL_INTERVAL=1000
